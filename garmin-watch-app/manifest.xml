<?xml version="1.0"?>
<!--
  Garmin Connect IQ application manifest for the EUC Planet companion. The
  UUID here must match GARMIN_APP_UUID in the phone-side bridge (see
  app/src/garminEnabled/kotlin/com/eried/eucplanet/garmin/GarminProtocol.kt)
  or the phone never finds the watch app.

  Permissions:
    Communications   — talk to the phone companion (snapshot in, control out)
    PersistedContent — remember a small bit of state across cold launches
                       (last-known telemetry frame so the dial doesn't flash
                       blank on app reopen)

  minApiLevel = 3.0.0 is the widest practical floor:
    - CIQ 2.0+ is the earliest version with phone-app messaging
      (`registerForPhoneAppMessages` + `Communications.transmit` of a
      Dictionary). Anything older literally can't talk to a phone companion
      so there's no path for those devices regardless of what we do here.
    - CIQ 3.0 is the first version where Dictionary round-trips through
      Connect Mobile cleanly across all platforms (early 2.x serializers
      mangled nested types on some Android builds).
    - The result: Fenix 5+/6/7/8, Forerunner 245+, Venu/Venu 2/3,
      Vivoactive 4+, Epix 2, MARQ Gen 2, Enduro, plus the modern Edge bike
      computers. Coverage is roughly every Garmin device from 2018 onwards.

  Device list is comprehensive; trim if a target isn't installed in your
  local SDK Manager (each entry must be in the SDK at build time or the
  compiler skips it). Adding a device later is just a new <iq:product> line.
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
  <iq:application
      entry="EucPlanetApp"
      type="watch-app"
      name="@Strings.AppName"
      launcherIcon="@Drawables.LauncherIcon"
      id="ee55b467-1529-4dfc-ac0f-c0d30c7cfdf5"
      minApiLevel="3.0.0">

    <iq:products>
      <!-- Top devices in Connect IQ (rolling install share, 2026):
           Fenix 8 AMOLED 12.7%, Fenix 6X Pro 10.4%, Fenix 8 Solar 47mm 6.5%,
           Fenix 8 Solar 51mm 6.4%, Epix Pro 47mm 5.8%, Epix Pro 51mm 5.5%,
           Venu 3 3.9% — covers ~51% of all CIQ devices.

           Every <iq:product id="…"/> needs a matching device profile
           installed in the local CIQ SDK Manager (Devices tab) or
           `monkeyc -e` errors out with "device ids not recognized". The
           list below maps the popular-device target list onto what's
           installable, with commented-out lines for devices that still
           need to be added via SDK Manager. After installing more
           devices, uncomment the matching <iq:product> entry and rebuild.

           To install missing devices: open the CIQ SDK Manager GUI, switch
           to the Devices tab, tick the boxes for the device IDs in the
           commented section below, and click Install. -->

      <!-- ===== Currently installed (build will compile for these) ===== -->

      <!-- Fenix 8 AMOLED (43 + 47 only; 51mm needs install) -->
      <iq:product id="fenix843mm"/>
      <iq:product id="fenix847mm"/>

      <!-- Fenix 8 Solar -->
      <iq:product id="fenix8solar47mm"/>
      <iq:product id="fenix8solar51mm"/>
      <iq:product id="fenix8pro47mm"/>

      <!-- Other modern Garmins the user has installed locally -->
      <iq:product id="fenixe"/>
      <iq:product id="fr70"/>
      <iq:product id="fr170"/>
      <iq:product id="fr170m"/>
      <iq:product id="fr57042mm"/>
      <iq:product id="fr57047mm"/>
      <iq:product id="fr970"/>
      <iq:product id="venu441mm"/>
      <iq:product id="venu445mm"/>
      <iq:product id="venux1"/>
      <iq:product id="vivoactive6"/>
      <iq:product id="enduro3"/>
      <iq:product id="d2mach2pro"/>

      <!-- Edge bike computers -->
      <iq:product id="edge540"/>
      <iq:product id="edge550"/>
      <iq:product id="edge840"/>
      <iq:product id="edge850"/>
      <iq:product id="edge1040"/>
      <iq:product id="edge1050"/>
      <iq:product id="edgemtb"/>

      <!-- ===== Install via SDK Manager → Devices, then uncomment =====
           These complete the popular-device priority list; without them,
           ~25% of in-the-wild Garmins won't get the EUC Planet companion. -->
      <!--
      <iq:product id="fenix851mm"/>      Fenix 8 AMOLED 51mm
      <iq:product id="fenix6xpro"/>      Fenix 6X Pro
      <iq:product id="fenix6xprosolar"/> Fenix 6X Pro Solar
      <iq:product id="fenix6xproapac"/>  Fenix 6X Pro APAC variant
      <iq:product id="epix2pro42mm"/>    Epix Pro Gen 2 42mm
      <iq:product id="epix2pro47mm"/>    Epix Pro Gen 2 47mm
      <iq:product id="epix2pro51mm"/>    Epix Pro Gen 2 51mm
      <iq:product id="venu3"/>           Venu 3
      <iq:product id="venu3s"/>          Venu 3S
      -->
    </iq:products>

    <iq:permissions>
      <iq:uses-permission id="Communications"/>
      <iq:uses-permission id="PersistedContent"/>
    </iq:permissions>

    <iq:languages>
      <iq:language>eng</iq:language>
      <!-- More locales tracked in the wear/ module's values-* directories:
           da, de, es, es-419, fr, it, nl, no, pl, pt-BR, ru, sv, uk. Port them
           into resources-<lang>/strings.xml as resources permit; English is
           the fallback. -->
    </iq:languages>

    <iq:barrels/>
  </iq:application>
</iq:manifest>
