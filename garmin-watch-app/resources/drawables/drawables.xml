<?xml version="1.0" encoding="UTF-8"?>
<!--
  Resource declarations. The launcher icon ships as a PNG so this file just
  points the manifest at it. Replace launcher_icon.png with a 40x40 (or
  device-appropriate, see CIQ docs) brand-aligned icon before publishing.
-->
<drawables>
  <bitmap id="LauncherIcon" filename="launcher_icon.png"/>

  <!-- Dial UI icons. 24x24 PNG, white-on-transparent so the bitmap can be
       drawn with any background colour underneath without colour clash.
       Generated by tools/gen-icons.ps1 (see repo docs) — if you regenerate,
       keep the same size and stroke weight or the dial composition shifts. -->
  <bitmap id="IconHorn" filename="icon_horn.png"/>
  <bitmap id="IconLight" filename="icon_light.png"/>
  <bitmap id="IconWheel" filename="icon_wheel.png"/>
  <bitmap id="IconPhone" filename="icon_phone.png"/>
  <bitmap id="IconWatch" filename="icon_watch.png"/>
</drawables>
