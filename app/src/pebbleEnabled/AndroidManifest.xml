<?xml version="1.0" encoding="utf-8"?>
<!--
  Pebble companion listener service. Lives ONLY on the `pebbleEnabled` source
  set so the slim `-PpebbleEnabled=false` build never references a class it
  doesn't ship (mirrors how the garminStub keeps the no-op build clean).

  PebbleKitAndroid2 binds this service via its RECEIVE_DATA_FROM_WATCH intent
  action to deliver watchapp open/close + inbound message events.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <service
            android:name="com.eried.eucplanet.pebble.PebbleListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="io.rebble.pebblekit2.RECEIVE_DATA_FROM_WATCH" />
            </intent-filter>
        </service>
    </application>
</manifest>
