    <path android:fillColor="#00000000" android:strokeColor="#40FFD740" android:strokeWidth="4"
        android:pathData="M32,40 Q42,38 48,44 Q54,50 62,46 Q70,42 78,46"/>
    <path android:fillColor="#00000000" android:strokeColor="#30FFD740" android:strokeWidth="3"
        android:pathData="M28,56 Q38,52 46,58 Q52,64 60,60 Q68,56 76,62"/>
</vector>
