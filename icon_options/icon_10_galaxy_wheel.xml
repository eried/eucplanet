<?xml version="1.0" encoding="utf-8"?>
<!-- 10: Galaxy Wheel - cosmic spiral inside wheel shape -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">
    <!-- Cosmic background fill -->
    <path android:pathData="M54,18 A36,36 0,1,1 53.99,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="54" android:centerY="54"
                android:gradientRadius="38">
                <item android:offset="0.0" android:color="#FF7C4DFF"/>
                <item android:offset="0.4" android:color="#FF311B92"/>
                <item android:offset="1.0" android:color="#FF0D0030"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Spiral arm 1 -->
    <path android:fillColor="#00000000" android:strokeWidth="3"
        android:pathData="M54,54 Q60,44 70,42 Q82,42 84,54 Q84,66 72,70 Q60,72 50,64">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear" android:startX="54" android:startY="54"
                android:endX="72" android:endY="70">
                <item android:offset="0.0" android:color="#FF7C4DFF"/>
                <item android:offset="1.0" android:color="#20B388FF"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Spiral arm 2 -->
    <path android:fillColor="#00000000" android:strokeWidth="3"
        android:pathData="M54,54 Q48,64 38,66 Q26,66 24,54 Q24,42 36,38 Q48,36 58,44">
