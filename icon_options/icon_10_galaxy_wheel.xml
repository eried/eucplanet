                android:endX="36" android:endY="38">
                <item android:offset="0.0" android:color="#FF7C4DFF"/>
                <item android:offset="1.0" android:color="#20B388FF"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Center star -->
    <path android:pathData="M54,50 A4,4 0,1,1 53.99,50 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="54" android:centerY="50"
                android:gradientRadius="6">
                <item android:offset="0.0" android:color="#FFFFFFFF"/>
                <item android:offset="1.0" android:color="#FFB388FF"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Outer rim -->
    <path android:pathData="M54,18 A36,36 0,1,1 53.99,18 Z M54,22 A32,32 0,1,0 54.01,22 Z">
        <aapt:attr name="android:fillColor">
