                <item android:offset="1.0" android:color="#FFFF9100"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Diagonal flares -->
    <path android:pathData="M20,20 L32,30 L28,32 L30,28 Z" android:fillColor="#60FF9100"/>
    <path android:pathData="M88,20 L76,30 L80,32 L78,28 Z" android:fillColor="#60FF9100"/>
    <path android:pathData="M20,88 L32,78 L28,76 L30,80 Z" android:fillColor="#60FF9100"/>
    <path android:pathData="M88,88 L76,78 L80,76 L78,80 Z" android:fillColor="#60FF9100"/>
