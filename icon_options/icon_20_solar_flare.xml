        </aapt:attr>
    </path>
    <path android:pathData="M54,102 L58,86 L54,90 L50,86 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="54" android:startY="102"
                android:endX="54" android:endY="86">
                <item android:offset="0.0" android:color="#40FF6D00"/>
                <item android:offset="1.0" android:color="#FFFF9100"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:pathData="M6,54 L22,50 L18,54 L22,58 Z">
