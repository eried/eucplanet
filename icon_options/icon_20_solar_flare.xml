    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">
    <!-- Corona flare rays -->
    <path android:pathData="M54,6 L58,22 L54,18 L50,22 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="54" android:startY="6"
                android:endX="54" android:endY="22">
                <item android:offset="0.0" android:color="#40FF6D00"/>
                <item android:offset="1.0" android:color="#FFFF9100"/>
